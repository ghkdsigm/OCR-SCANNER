generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OcrResult {
  id         Int      @id @default(autoincrement())
  receiptId  String   @unique
  mappedData Json
  confidence Float
  status     String
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@map("ocr_results")
}
